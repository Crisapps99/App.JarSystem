<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- PANEL DE RESULTADOS (se colocará justo encima de la barra) -->
    <FrameLayout
        android:id="@+id/frameContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:visibility="gone"
        android:elevation="0dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="15dp">   <!-- sin elevación para que la barra quede encima -->

        <LinearLayout
            android:id="@+id/resultsPanelInner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:animateLayoutChanges="true"
            android:background="@drawable/panel_background_rounded"> <!-- crea este drawable -->
            <!-- carrusel de imágenes -->
            <HorizontalScrollView
                android:id="@+id/imagesScrollView"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:visibility="gone"
                android:scrollbars="none"
                android:overScrollMode="never" />
            <!-- texto desplazable -->
            <ScrollView
                android:id="@+id/scrollText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:fadeScrollbars="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="20dp"
                android:maxHeight="340dp"
                android:maxLines="8" >
                <TextView
                    android:id="@+id/tvTranscription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#E8E8F0"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:maxLines="100"
                    android:layout_marginBottom="100dp"/>
            </ScrollView>
            <!-- chips -->
            <LinearLayout
                android:id="@+id/chipsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="130dp"
                android:visibility="gone" />
        </LinearLayout>
    </FrameLayout>

    <!-- BARRA INFERIOR (sobrepuesta, con elevación) -->
    <com.example.myapplication.ui.ListeningBarView
        android:id="@+id/containerOuter"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:minHeight="68dp"
        android:layout_marginBottom="33dp"
        android:elevation="8dp">   <!-- para que se dibuje encima del panel -->

        <!-- contenido interno de la barra (igual que tenías) -->
        <com.example.myapplication.ui.JarvisOrbView
            android:id="@+id/jarvisOrb"
            android:layout_width="52dp"
            android:layout_height="42dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="12dp"
            app:showLightCore="false"
            app:showParticles="false"
            app:showTravelingOrbs="false"
            app:maxRings="3" />

        <TextView
            android:id="@+id/tvListeningLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NEXUS"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08"
            android:gravity="center_vertical" />

        <FrameLayout
            android:id="@+id/btnPauseContainer"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="6dp"
            android:background="@android:color/transparent"
            android:visibility="gone">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_media_pause"
                android:alpha="0.85"
                app:tint="#FFFFFF" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnMicContainer"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp">
            <ImageView
                android:id="@+id/ivMicIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_btn_speak_now"
                android:alpha="0.75"
                app:tint="#AAAACC" />
            <com.example.myapplication.ui.VoiceWaveView
                android:id="@+id/voiceWaveView"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:visibility="gone" />
        </FrameLayout>

    </com.example.myapplication.ui.ListeningBarView>

</FrameLayout>