<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00000000"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="48dp">

        <!-- Borde animado envuelve todo -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="80dp">

            <!-- Vista que dibuja solo el borde animado -->
            <com.example.myapplication.ui.ListeningBarView
                android:id="@+id/listeningBar"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Contenido interior blanco -->
            <LinearLayout
                android:id="@+id/containerOuter"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_listening_container"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_margin="3dp"
                android:paddingStart="6dp"
                android:paddingEnd="12dp">

                <com.example.myapplication.ui.JarvisOrbView
                    android:id="@+id/jarvisOrb"
                    android:layout_width="72dp"
                    android:layout_height="72dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvListeningLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NEXUS"
                        android:textColor="#1A1A2E"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvTranscription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#444466"
                        android:textSize="12sp"
                        android:maxLines="1"
                        android:ellipsize="end" />

                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

</FrameLayout>