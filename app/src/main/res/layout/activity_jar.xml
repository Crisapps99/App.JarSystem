<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/jar_gradient_background"
    tools:context=".activity.JarActivity">

    <com.example.myapplication.ui.JarvisOrbView
        android:id="@+id/jarvisOrb"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:visibility="visible"
        android:elevation="0dp"
        android:translationZ="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="-100dp"/>
<TextView
    android:id="@+id/titleWel"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Hola"
    android:textSize="32sp"
    android:textStyle="bold"
    android:textColor="@color/text_primary"
    android:fontFamily="@font/googlesans"
    android:elevation="10dp"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginTop="100dp"/>
    <TextView
        android:id="@+id/instructionsText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="16dp"
        android:text="Prueba diciendo:\n&quot;Hola Jarvis&quot;"
        android:textSize="20sp"
        android:textColor="@color/text_primary"
        android:fontFamily="@font/googlesans"
        android:gravity="center"
        android:elevation="10dp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@id/titleWel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
        android:id="@+id/transcriptionTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="32dp"
        android:text=""
        android:textSize="16sp"
        android:textColor="@color/white"
        android:fontFamily="@font/googlesans"
        android:gravity="center"
        android:elevation="10dp"
        android:padding="16dp"
        android:background="@drawable/transcription_background"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/jarvisOrb"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Esperando..."
        android:textSize="14sp"
        android:textColor="#80FFFFFF"
        android:fontFamily="@font/googlesans"
        android:elevation="10dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/instructionsText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>
