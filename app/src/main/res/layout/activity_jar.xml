<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    tools:context=".activity.JarActivity">

    <!-- Botón Omitir en la esquina superior derecha -->
    <Button
        android:id="@+id/btnOmitir"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Omitir introducción"
        android:textColor="#A0A0A0"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:visibility="gone"
        tools:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"/>

    <!-- Orbe principal centrado debajo del botón Omitir y arriba de la tarjeta -->
    <com.example.myapplication.ui.JarvisOrbView
        android:id="@+id/jarvisOrb"
        android:layout_width="390dp"
        android:layout_height="390dp"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/btnOmitir"
        app:layout_constraintBottom_toTopOf="@id/cardTranscription"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"/>

    <!-- Tarjeta de presentación/transcripción -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardTranscription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:alpha="0"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="#1E2022"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toTopOf="@id/btnComenzar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:id="@+id/statusIndicatorRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <View
                    android:id="@+id/statusDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@color/primary_dark"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/statusLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NEXUS"
                    android:textSize="10sp"
                    android:textColor="@color/primary_dark"
                    android:fontFamily="@font/googlesans"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"/>
            </LinearLayout>

            <TextView
                android:id="@+id/transcriptionTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/googlesans"
                android:lineSpacingMultiplier="1.5"
                android:minLines="2"/>

            <TextView
                android:id="@+id/instructionsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#A0A0A0"
                android:fontFamily="@font/googlesans"
                android:layout_marginTop="8dp"
                android:lineSpacingMultiplier="1.4"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Botón Skip Oculto -->
    <Button
        android:id="@+id/btnSkip"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="16dp"
        android:text="⏭Omitir"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_skip_dradient"
        android:visibility="gone"
        android:alpha="0"
        android:translationY="20dp"
        app:layout_constraintBottom_toTopOf="@id/btnComenzar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Componente Deslizable -->
    <com.ncorti.slidetoact.SlideToActView
        android:id="@+id/btnComenzar"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="48dp"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:area_margin="8dp"
        app:outer_color="#1E2022"
        app:inner_color="@color/primary_dark"
        app:border_radius="30dp"
        app:text="Desliza para comenzar"
        app:text_color="@color/primary_dark"
        app:text_size="16sp"
        app:slider_icon="@drawable/ic_mic_vector"
        app:slider_icon_color="#FFFFFF" />

</androidx.constraintlayout.widget.ConstraintLayout>