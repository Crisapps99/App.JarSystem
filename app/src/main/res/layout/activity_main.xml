<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    tools:context=".MainActivity">

    <!-- Orbe central (reemplaza al Lottie) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/orbContainer"
        android:layout_width="280dp"
        android:layout_height="280dp"
        app:cardCornerRadius="190dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/textView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="32dp">

        <com.example.myapplication.ui.JarvisOrbView
            android:id="@+id/orbView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </androidx.cardview.widget.CardView>

    <!-- Título principal -->
    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="JARVOICE"
        android:textSize="42sp"
        android:textStyle="bold"
        android:fontFamily="@font/googlesans"
        android:textColor="@color/white"
        android:letterSpacing="0.05"
        app:layout_constraintTop_toBottomOf="@id/orbContainer"
        app:layout_constraintBottom_toTopOf="@id/textViewSub"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Subtítulo -->
    <TextView
        android:id="@+id/textViewSub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tu asistente de voz inteligente"
        android:textSize="16sp"
        android:fontFamily="@font/googlesans"
        android:textColor="#B3FFFFFF"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/textView"
        app:layout_constraintBottom_toTopOf="@id/Ingresobutton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Botón slide to act -->
    <com.ncorti.slidetoact.SlideToActView
        android:id="@+id/Ingresobutton"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:area_margin="6dp"
        app:outer_color="#4D4DEEE9"
        app:inner_color="#4DEEE9"
        app:border_radius="35dp"
        app:text_size="18sp"
        app:slider_icon="@drawable/ic_mic_vector"/>

</androidx.constraintlayout.widget.ConstraintLayout>