<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".activity.LoginActivity">

    <TextView
        android:id="@+id/titleApp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NEXUS"
        android:textSize="38sp"
        android:textStyle="bold"
        android:fontFamily="@font/googlesans"
        android:textColor="#1A1A1A"
        android:letterSpacing="0.05"
        android:layout_marginTop="52dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/subtitleApp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Activa los permisos para comenzar"
        android:textSize="14sp"
        android:fontFamily="@font/googlesans"
        android:textColor="#666666"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/titleApp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:id="@+id/scrollPermisos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/subtitleApp"
        app:layout_constraintBottom_toTopOf="@id/btnContinue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Permisos necesarios"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/googlesans"
                    android:layout_marginBottom="14dp"/>

                <!-- Micrófono -->
                <LinearLayout
                    android:id="@+id/rowMicrofono"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp"
                    android:background="#F5F5F5"
                    android:paddingStart="14dp"
                    android:paddingEnd="10dp"
                    android:visibility="visible">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_mic_vector"
                        android:contentDescription="Micrófono"
                        app:tint="#0095D4"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Micrófono"
                            android:textColor="#1A1A1A"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/googlesans"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Para escucharte y responder"
                            android:textColor="#999999"
                            android:textSize="11sp"
                            android:fontFamily="@font/googlesans"/>
                    </LinearLayout>
                    <Button
                        android:id="@+id/btnMicrofono"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Activar"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/googlesans"
                        android:backgroundTint="#E53935"
                        android:stateListAnimator="@null"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        app:cornerRadius="20dp"/>
                </LinearLayout>

                <!-- Superposición -->
                <LinearLayout
                    android:id="@+id/rowOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp"
                    android:background="#F5F5F5"
                    android:paddingStart="14dp"
                    android:paddingEnd="10dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_menu_view"
                        android:contentDescription="Superposición"
                        app:tint="#0095D4"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Superposición"
                            android:textColor="#1A1A1A"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/googlesans"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Para mostrar el orbe flotante"
                            android:textColor="#999999"
                            android:textSize="11sp"
                            android:fontFamily="@font/googlesans"/>
                    </LinearLayout>
                    <Button
                        android:id="@+id/btnOverlay"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Activar"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/googlesans"
                        android:backgroundTint="#E53935"
                        android:stateListAnimator="@null"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        app:cornerRadius="20dp"/>
                </LinearLayout>

                <!-- Accesibilidad -->
                <LinearLayout
                    android:id="@+id/rowAccesibilidad"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp"
                    android:background="#F5F5F5"
                    android:paddingStart="14dp"
                    android:paddingEnd="10dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_menu_help"
                        android:contentDescription="Accesibilidad"
                        app:tint="#0095D4"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Accesibilidad"
                            android:textColor="#1A1A1A"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/googlesans"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Para leer y entender tu pantalla"
                            android:textColor="#999999"
                            android:textSize="11sp"
                            android:fontFamily="@font/googlesans"/>
                    </LinearLayout>
                    <Button
                        android:id="@+id/btnAccesibilidad"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Activar"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/googlesans"
                        android:backgroundTint="#E53935"
                        android:stateListAnimator="@null"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        app:cornerRadius="20dp"/>
                </LinearLayout>

                <!-- Notificaciones -->
                <LinearLayout
                    android:id="@+id/rowNotificaciones"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp"
                    android:background="#F5F5F5"
                    android:paddingStart="14dp"
                    android:paddingEnd="10dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_popup_reminder"
                        android:contentDescription="Notificaciones"
                        app:tint="#0095D4"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notificaciones"
                            android:textColor="#1A1A1A"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/googlesans"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Para leer mensajes y alertas"
                            android:textColor="#999999"
                            android:textSize="11sp"
                            android:fontFamily="@font/googlesans"/>
                    </LinearLayout>
                    <Button
                        android:id="@+id/btnNotificaciones"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Activar"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/googlesans"
                        android:backgroundTint="#E53935"
                        android:stateListAnimator="@null"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        app:cornerRadius="20dp"/>
                </LinearLayout>

                <!-- Contactos -->
                <LinearLayout
                    android:id="@+id/rowContactos"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp"
                    android:background="#F5F5F5"
                    android:paddingStart="14dp"
                    android:paddingEnd="10dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:contentDescription="Contactos"
                        app:tint="#0095D4"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Contactos"
                            android:textColor="#1A1A1A"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/googlesans"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Para llamar y enviar mensajes"
                            android:textColor="#999999"
                            android:textSize="11sp"
                            android:fontFamily="@font/googlesans"/>
                    </LinearLayout>
                    <Button
                        android:id="@+id/btnContactos"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Activar"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/googlesans"
                        android:backgroundTint="#E53935"
                        android:stateListAnimator="@null"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        app:cornerRadius="20dp"/>
                </LinearLayout>

                <!-- Llamadas -->
                <LinearLayout
                    android:id="@+id/rowLlamadas"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#F5F5F5"
                    android:paddingStart="14dp"
                    android:paddingEnd="10dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_menu_call"
                        android:contentDescription="Llamadas"
                        app:tint="#0095D4"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Llamadas"
                            android:textColor="#1A1A1A"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/googlesans"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Para realizar llamadas por voz"
                            android:textColor="#999999"
                            android:textSize="11sp"
                            android:fontFamily="@font/googlesans"/>
                    </LinearLayout>
                    <Button
                        android:id="@+id/btnLlamadas"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Activar"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/googlesans"
                        android:backgroundTint="#E53935"
                        android:stateListAnimator="@null"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        app:cornerRadius="20dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </ScrollView>

    <com.ncorti.slidetoact.SlideToActView
        android:id="@+id/btnContinue"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="36dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:area_margin="6dp"
        app:outer_color="#4D0095D4"
        app:inner_color="#0095D4"
        app:border_radius="35dp"
        app:text="Comenzar con Jarvoice"
        app:text_size="15sp"
        app:slider_icon="@drawable/ic_mic_vector"/>

</androidx.constraintlayout.widget.ConstraintLayout>