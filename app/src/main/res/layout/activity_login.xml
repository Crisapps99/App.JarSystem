<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0B0C"
    tools:context=".activity.LoginActivity">

    <com.example.myapplication.ui.AmbientGlowView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/scrollPermisos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Configuración de Nexus"
                android:textSize="26sp"
                android:fontFamily="@font/googlesans"
                android:textStyle="bold"
                android:textColor="#e2e2e5"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="290dp"
                android:layout_height="wrap_content"
                android:text="Activa los siguientes accesos para otorgar capacidades completas de automatización y control a tu asistente."
                android:textSize="14sp"
                android:fontFamily="@font/googlesans"
                android:textColor="#8b90a0"
                android:gravity="center"
                android:layout_marginBottom="32dp" />

            <LinearLayout
                android:id="@+id/panelMicrophone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_permission_card"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_circle_primary"
                    android:gravity="center"
                    android:layout_marginEnd="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱"
                        android:textSize="22sp" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Micrófono"
                        android:textSize="16sp"
                        android:fontFamily="@font/googlesans"
                        android:textStyle="bold"
                        android:textColor="#e2e2e5"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Para escuchar tus comandos de voz."
                        android:textSize="13sp"
                        android:textColor="#8b90a0" />
                </LinearLayout>
                <CheckBox
                    android:id="@+id/checkMicrophone"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:clickable="false"
                    android:focusable="false"
                    android:button="@null"
                    android:background="@drawable/bg_checkbox_selector" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelOverlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_permission_card"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_circle_secondary"
                    android:gravity="center"
                    android:layout_marginEnd="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔳"
                        android:textSize="22sp" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Superposición"
                        android:textSize="16sp"
                        android:fontFamily="@font/googlesans"
                        android:textStyle="bold"
                        android:textColor="#e2e2e5"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Para mostrar el orbe flotante sobre otras apps."
                        android:textSize="13sp"
                        android:textColor="#8b90a0" />
                </LinearLayout>
                <CheckBox
                    android:id="@+id/checkOverlay"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:clickable="false"
                    android:focusable="false"
                    android:button="@null"
                    android:background="@drawable/bg_checkbox_selector" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelAccessibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_permission_card"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_circle_primary"
                    android:gravity="center"
                    android:layout_marginEnd="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="♿"
                        android:textSize="22sp" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Accesibilidad"
                        android:textSize="16sp"
                        android:fontFamily="@font/googlesans"
                        android:textStyle="bold"
                        android:textColor="#e2e2e5"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Para leer, entender tu pantalla y automatizar acciones."
                        android:textSize="13sp"
                        android:textColor="#8b90a0" />
                </LinearLayout>
                <CheckBox
                    android:id="@+id/checkAccessibility"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:clickable="false"
                    android:focusable="false"
                    android:button="@null"
                    android:background="@drawable/bg_checkbox_selector" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelNotifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_permission_card"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_tertiary"
                    android:gravity="center"
                    android:layout_marginEnd="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔔"
                        android:textSize="22sp" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notificaciones"
                        android:textSize="16sp"
                        android:fontFamily="@font/googlesans"
                        android:textStyle="bold"
                        android:textColor="#e2e2e5"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Para leer tus mensajes entrantes y alertas."
                        android:textSize="13sp"
                        android:textColor="#8b90a0" />
                </LinearLayout>
                <CheckBox
                    android:id="@+id/checkNotifications"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:clickable="false"
                    android:focusable="false"
                    android:button="@null"
                    android:background="@drawable/bg_checkbox_selector" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelContacts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_permission_card"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_circle_secondary"
                    android:gravity="center"
                    android:layout_marginEnd="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👥"
                        android:textSize="22sp" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contactos"
                        android:textSize="16sp"
                        android:fontFamily="@font/googlesans"
                        android:textStyle="bold"
                        android:textColor="#e2e2e5"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Para identificar a quién llamar o enviar mensajes."
                        android:textSize="13sp"
                        android:textColor="#8b90a0" />
                </LinearLayout>
                <CheckBox
                    android:id="@+id/checkContacts"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:clickable="false"
                    android:focusable="false"
                    android:button="@null"
                    android:background="@drawable/bg_checkbox_selector" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_permission_card"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_tertiary"
                    android:gravity="center"
                    android:layout_marginEnd="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="☎️"
                        android:textSize="22sp" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Teléfono"
                        android:textSize="16sp"
                        android:fontFamily="@font/googlesans"
                        android:textStyle="bold"
                        android:textColor="#e2e2e5"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Para iniciar llamadas salientes directamente por voz."
                        android:textSize="13sp"
                        android:textColor="#8b90a0" />
                </LinearLayout>
                <CheckBox
                    android:id="@+id/checkPhone"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:clickable="false"
                    android:focusable="false"
                    android:button="@null"
                    android:background="@drawable/bg_checkbox_selector" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelCamera"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_permission_card"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_circle_primary"
                    android:gravity="center"
                    android:layout_marginEnd="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📷"
                        android:textSize="22sp" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cámara"
                        android:textSize="16sp"
                        android:fontFamily="@font/googlesans"
                        android:textStyle="bold"
                        android:textColor="#e2e2e5"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Para tomar fotos y capturar video bajo tus comandos."
                        android:textSize="13sp"
                        android:textColor="#8b90a0" />
                </LinearLayout>
                <CheckBox
                    android:id="@+id/checkCamera"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:clickable="false"
                    android:focusable="false"
                    android:button="@null"
                    android:background="@drawable/bg_checkbox_selector" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnFinalizeSetup"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="CONTINUAR A NEXUS ➔"
            android:textSize="13sp"
            android:fontFamily="@font/googlesans"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:textColor="#002e69"
            android:background="@drawable/btn_allow_all" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>