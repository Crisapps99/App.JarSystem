From 3ef94d6b7b285e1c81b64a89ba3dc8702d92e1ab Mon Sep 17 00:00:00 2001
From: Jar System Dev <dev@jarsystem.local>
Date: Sun, 5 Jul 2026 18:58:46 +0000
Subject: [PATCH] refactor: usar apikeys.properties en vez de local.properties
 para las API keys

- local.properties queda reservado solo para configuracion del SDK (uso recomendado por Android)
- Nueva propiedad apikeys.properties (ignorada por git) para las claves sensibles
- build.gradle.kts ahora lee apikeys.properties en vez de local.properties
- Se agrega apikeys.properties.example como plantilla versionada
---
 .gitignore                                             | 1 +
 local.properties.example => apikeys.properties.example | 5 +----
 app/build.gradle.kts                                   | 6 +++---
 3 files changed, 5 insertions(+), 7 deletions(-)
 rename local.properties.example => apikeys.properties.example (57%)

diff --git a/.gitignore b/.gitignore
index aa724b7..70dab78 100644
--- a/.gitignore
+++ b/.gitignore
@@ -13,3 +13,4 @@
 .externalNativeBuild
 .cxx
 local.properties
+/apikeys.properties
diff --git a/local.properties.example b/apikeys.properties.example
similarity index 57%
rename from local.properties.example
rename to apikeys.properties.example
index 5d2d0fe..718d8e6 100644
--- a/local.properties.example
+++ b/apikeys.properties.example
@@ -1,7 +1,4 @@
-# Copia este archivo como "local.properties" (ya ignorado por git) y completa tus claves reales.
-# Ruta del SDK de Android (la genera Android Studio automáticamente)
-# sdk.dir=/ruta/a/tu/Android/Sdk
-
+# Copia este archivo como "apikeys.properties" (ya ignorado por git) en la RAIZ del proyecto y completa tus claves reales.
 GEMINI_API_KEY=
 YOUTUBE_API_KEY=
 TAVILY_API_KEY=
diff --git a/app/build.gradle.kts b/app/build.gradle.kts
index aa472a1..df3f6c0 100644
--- a/app/build.gradle.kts
+++ b/app/build.gradle.kts
@@ -33,9 +33,9 @@ android {
             "redirectHostName" to "auth"
         ))
         val props = Properties()
-        val localPropsFile = rootProject.file("local.properties")
-        if (localPropsFile.exists()) {
-            props.load(localPropsFile.inputStream())
+        val apiKeysFile = rootProject.file("apikeys.properties")
+        if (apiKeysFile.exists()) {
+            props.load(apiKeysFile.inputStream())
         }
         val geminiKey = props.getProperty("GEMINI_API_KEY") ?: ""
         buildConfigField("String", "GEMINI_API_KEY", "\"$geminiKey\"")
-- 
2.43.0

